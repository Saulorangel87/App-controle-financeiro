# Copie este arquivo para ".env" (na raiz do projeto, ao lado do
# docker-compose.yml) e preencha os valores reais antes de rodar
# `docker compose up -d --build`.

# Gere com: openssl rand -hex 32
JWT_SECRET=troque-por-um-segredo-aleatorio

# Domínio público do frontend (usado pelo backend pra liberar o CORS)
FRONTEND_URL=http://localhost:8091

# Domínio público da API (usado pelo frontend no momento do build)
VITE_API_URL=http://localhost:3011/api

# Chave da API do Resend (resend.com/api-keys) — usada pra enviar email de
# confirmação de cadastro e recuperação de senha. Sem essa variável, o
# backend não trava: só imprime o link no log do servidor em vez de mandar
# o email de verdade (útil pra testar local).
RESEND_API_KEY=

# Remetente que aparece nos emails enviados. Precisa ser de um domínio já
# verificado no Resend.
EMAIL_REMETENTE=Controle de Despesas <no-reply@devsaulo.com.br>
