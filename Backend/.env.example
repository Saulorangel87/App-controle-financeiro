# Copie este arquivo para ".env" e preencha os valores reais.
# NUNCA suba o arquivo ".env" de verdade pro Git — ele tem segredos.

# Gere com: openssl rand -hex 32
JWT_SECRET=troque-por-um-segredo-aleatorio

# URL pública do frontend em produção (sem barra no final)
# Ex: https://despesas.devsaulo.com.br
FRONTEND_URL=http://localhost:8091

NODE_ENV=development
PORT=3001

# Chave da API do Resend (resend.com/api-keys). Sem ela, o backend não
# trava — só imprime o link de verificação/recuperação no console em vez
# de mandar o email de verdade (útil pra testar local).
RESEND_API_KEY=
EMAIL_REMETENTE=Controle de Despesas <no-reply@devsaulo.com.br>
